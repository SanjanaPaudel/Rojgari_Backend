# Django settings
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database URL
# For SQLite local development: sqlite:///db.sqlite3
# For PostgreSQL container: postgres://rojgari_user:rojgari_password@db:5432/rojgari_db
DATABASE_URL=sqlite:///db.sqlite3

# Caching URL (using Valkey / Redis protocol)
# For local development: redis://127.0.0.1:6379/1
# For Valkey container: redis://valkey:6379/1
CACHE_URL=redis://127.0.0.1:6379/1
