### Rojgari API HTTP Request Sandbox (Updated)
# Use this file with the "REST Client" extension in VS Code / Cursor.

@baseUrl = http://localhost:8000/api
@cust_user = customer_user_http
@work_user = worker_user_http
@password = Password123!

###
# @name registerCustomer
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "{{cust_user}}",
  "email": "customer_http@example.com",
  "password": "{{password}}",
  "full_name": "HTTP Customer User",
  "phone_number": "+977-9800000001",
  "role": "customer"
}

###
# @name registerWorker
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "{{work_user}}",
  "email": "worker_http@example.com",
  "password": "{{password}}",
  "full_name": "HTTP Worker User",
  "phone_number": "+977-9800000002",
  "role": "worker"
}

###
# @name loginCustomer
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{cust_user}}",
  "password": "{{password}}"
}

###
# @name getMe
GET {{baseUrl}}/auth/me
Accept: application/json

###
# @name listCategories
GET {{baseUrl}}/categories
Accept: application/json

###
# @name createServiceRequest
# (Run as Customer. Select category ID from category listing)
POST {{baseUrl}}/requests
Content-Type: application/json

{
  "category_id": "c1a9668d-862d-4cc0-84b3-d3450974cfc7",
  "description": "Fixing a kitchen sink pipe leak.",
  "customer_lat": 27.7172,
  "customer_lng": 85.3240,
  "address": "Lazimpat, Kathmandu"
}

###
# @name loginWorker
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{work_user}}",
  "password": "{{password}}"
}

###
# @name submitWorkerDocument
POST {{baseUrl}}/workers/document
Content-Type: application/json

{
  "document_type": "driving_license",
  "file_url": "https://example.com/license.jpg"
}

###
# @name addWorkerService
POST {{baseUrl}}/workers/services
Content-Type: application/json

{
  "category_id": "c1a9668d-862d-4cc0-84b3-d3450974cfc7",
  "years_experience": 5,
  "skill_level": "Expert",
  "hourly_rate": 45.50
}

###
# @name acceptServiceRequest
# (Replace {request_id} with actual UUID)
POST {{baseUrl}}/bookings/2f9c8d50-e3a5-4f36-9694-dfba0d2e8b2e/accept
Accept: application/json

###
# @name updateBookingStatus
# (Replace {booking_id} with actual UUID)
PUT {{baseUrl}}/bookings/0c4eb5e7-a9a3-4819-bf9f-0ff7dc12903b/status
Content-Type: application/json

{
  "status": "completed"
}

###
# @name recordPayment
# (Run as Customer to checkout booking)
POST {{baseUrl}}/payments/checkout
Content-Type: application/json

{
  "booking_id": "0c4eb5e7-a9a3-4819-bf9f-0ff7dc12903b",
  "amount": 91.00,
  "method": "esewa",
  "transaction_ref": "ESEWA_REF_998877"
}

###
# @name submitReview
POST {{baseUrl}}/reviews
Content-Type: application/json

{
  "booking_id": "0c4eb5e7-a9a3-4819-bf9f-0ff7dc12903b",
  "rating": 5,
  "comment": "Did a clean job and arrived on time!"
}

###
# @name getNotifications
GET {{baseUrl}}/notifications
Accept: application/json

###
# @name logout
POST {{baseUrl}}/auth/logout
